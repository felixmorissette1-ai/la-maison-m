{% comment %} Panneau de prévisualisation — Configurateur Custom — v5 {% endcomment %}

<style>
  .lmm-sm-preview {
    position: fixed;
    top: calc(72px + 16px);
    right: 16px;
    width: 30vw;
    height: calc(100vh - 72px - 32px);
    background: #fff;
    border: 1px solid var(--lmm-border);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    z-index: 50;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0,0,0,0.06);
  }

  .lmm-sm-preview__header {
    padding: 16px 20px 12px;
    border-bottom: 1px solid var(--lmm-border);
    flex-shrink: 0;
  }

  .lmm-sm-preview__label {
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lmm-gold);
    margin-bottom: 3px;
  }

  .lmm-sm-preview__title {
    font-family: Georgia, serif;
    font-size: 14px;
    color: var(--lmm-text);
    font-weight: 400;
  }

  /* 1. Style — grande photo principale */
  .lmm-sm-preview__style {
    flex: 3;
    min-height: 0;
    position: relative;
    background: var(--lmm-surface);
    overflow: hidden;
    padding: 10px;
  }

  .lmm-sm-preview__style img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: none;
    background: #fff;
  }

  .lmm-sm-preview__style-empty {
    position: absolute;
    inset: 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: #fff;
  }

  .lmm-sm-preview__style-empty-icon {
    width: 36px;
    height: 36px;
    opacity: 0.2;
  }

  .lmm-sm-preview__style-empty-text {
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #B8AFA8;
    text-align: center;
    padding: 0 24px;
  }

  /* 2. Tissu — bande pleine largeur */
  .lmm-sm-preview__tissu {
    flex: 1;
    min-height: 0;
    position: relative;
    background: var(--lmm-surface);
    overflow: hidden;
    border-top: 1px solid var(--lmm-border);
    padding: 10px;
  }

  .lmm-sm-preview__tissu img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.3s ease;
    background: #fff;
  }

  .lmm-sm-preview__tissu img.loaded { opacity: 1; }

  /* 3. Lining + Boutons — rangée côte à côte */
  .lmm-sm-preview__row {
    flex: 1;
    min-height: 0;
    display: flex;
    gap: 10px;
    padding: 10px;
    border-top: 1px solid var(--lmm-border);
    background: var(--lmm-surface);
  }

  .lmm-sm-preview__swatch {
    flex: 1;
    position: relative;
    background: #fff;
    overflow: hidden;
  }

  .lmm-sm-preview__swatch img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .lmm-sm-preview__swatch img.loaded { opacity: 1; }

  /* 4. Textes — construction, hauteur, bas */
  .lmm-sm-preview__texts {
    border-top: 1px solid var(--lmm-border);
    flex-shrink: 0;
    padding: 10px 20px;
    display: flex;
    gap: 0;
    flex-direction: column;
    gap: 4px;
  }

  .lmm-sm-preview__text-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .lmm-sm-preview__text-key {
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--lmm-border);
  }

  .lmm-sm-preview__text-val {
    font-size: 11px;
    color: var(--lmm-text);
    font-family: Georgia, serif;
  }

  .lmm-sm-preview__text-val--empty {
    color: #D0C8C0;
    font-style: italic;
    font-family: inherit;
    font-size: 10px;
  }

  /* 5. Bouton Continuer */
  .lmm-sm-preview__footer {
    padding: 14px 20px;
    border-top: 1px solid var(--lmm-border);
    flex-shrink: 0;
  }

  .lmm-sm-preview__btn {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: var(--lmm-text);
    color: #ffffff;
    border: none;
    padding: 13px 20px;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    font-family: inherit;
    opacity: 0.35;
    pointer-events: none;
    transition: background 0.2s, opacity 0.2s;
    box-sizing: border-box;
  }

  .lmm-sm-preview__btn:hover { background: var(--lmm-text); }
  .lmm-sm-preview__btn.active { opacity: 1; pointer-events: auto; }

  /* Desktop */
  @media (min-width: 861px) {
    .lmm-sm-main {
      width: auto !important;
      margin-left: 5% !important;
      margin-right: calc(30vw + 36px) !important;
    }
  }

  /* Mobile — barre fixe en bas */
  @media (max-width: 860px) {
    .lmm-sm-preview {
      position: fixed;
      top: auto; right: 0; bottom: 0; left: 0;
      width: 100%; height: auto;
      flex-direction: row;
      border-left: none;
      border-top: 1px solid var(--lmm-border);
      z-index: 50;
      padding-bottom: env(safe-area-inset-bottom, 0px);
    }

    .lmm-sm-preview__header { display: none; }

    .lmm-sm-preview__style {
      width: 56px; height: 56px;
      flex: none; flex-shrink: 0;
      border-right: 1px solid var(--lmm-border);
    }
    .lmm-sm-preview__style-empty { display: none; }

    .lmm-sm-preview__tissu {
      width: 56px; height: 56px;
      border-top: none;
      border-right: 1px solid var(--lmm-border);
      flex-shrink: 0;
    }

    .lmm-sm-preview__row {
      height: 56px;
      border-top: none;
      border-right: 1px solid var(--lmm-border);
      padding: 4px;
      gap: 4px;
      flex-shrink: 0;
      width: 114px;
    }

    .lmm-sm-preview__swatch { border-radius: 2px; }

    /* Textes : cachés sur mobile */
    .lmm-sm-preview__texts { display: none; }

    .lmm-sm-preview__footer {
      border-top: none;
      border-left: 1px solid var(--lmm-border);
      padding: 0 12px;
      display: flex;
      align-items: center;
      flex: 1;
    }

    .lmm-sm-preview__btn {
      width: 100%;
      padding: 10px 14px;
      font-size: 10px;
      white-space: nowrap;
    }

    .lmm-sm-main {
      padding-bottom: calc(72px + env(safe-area-inset-bottom, 0px)) !important;
    }
  }
</style>

<div class="lmm-sm-preview" id="lmm-sm-preview">
  <div class="lmm-sm-preview__header">
    <p class="lmm-sm-preview__label">Aperçu</p>
    <p class="lmm-sm-preview__title">Votre complet</p>
  </div>

  <!-- 1. Style — grande photo -->
  <div class="lmm-sm-preview__style" id="lmm-prev-style">
    <img id="lmm-prev-style-img" src="" alt="">
    <div class="lmm-sm-preview__style-empty" id="lmm-prev-empty">
      <svg class="lmm-sm-preview__style-empty-icon" viewBox="0 0 60 80" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 8 L8 20 L2 22 L2 72 L58 72 L58 22 L52 20 L48 8 L38 14 C36 18 24 18 22 14 Z" stroke="var(--lmm-text)" stroke-width="1.5" fill="none"/>
        <path d="M22 14 L24 28 L30 34 L36 28 L38 14" stroke="var(--lmm-text)" stroke-width="1.5" fill="none"/>
        <line x1="10" y1="30" x2="10" y2="68" stroke="var(--lmm-text)" stroke-width="1" opacity="0.4"/>
        <line x1="50" y1="30" x2="50" y2="68" stroke="var(--lmm-text)" stroke-width="1" opacity="0.4"/>
      </svg>
      <span class="lmm-sm-preview__style-empty-text">Choisissez votre style pour commencer</span>
    </div>
  </div>

  <!-- 2. Tissu — bande pleine largeur -->
  <div class="lmm-sm-preview__tissu">
    <img id="lmm-prev-tissu-img" src="" alt="">
  </div>

  <!-- 3. Lining + Boutons — rangée côte à côte -->
  <div class="lmm-sm-preview__row">
    <div class="lmm-sm-preview__swatch">
      <img id="lmm-prev-lining-img" src="" alt="">
    </div>
    <div class="lmm-sm-preview__swatch">
      <img id="lmm-prev-bouton-img" src="" alt="">
    </div>
  </div>

  <!-- 4. Construction · Hauteur · Bas -->
  <div class="lmm-sm-preview__texts">
    <div class="lmm-sm-preview__text-row">
      <span class="lmm-sm-preview__text-key">Construction</span>
      <span class="lmm-sm-preview__text-val lmm-sm-preview__text-val--empty" id="lmm-prev-const-val">—</span>
    </div>
    <div class="lmm-sm-preview__text-row">
      <span class="lmm-sm-preview__text-key">Hauteur</span>
      <span class="lmm-sm-preview__text-val lmm-sm-preview__text-val--empty" id="lmm-prev-hauteur">—</span>
    </div>
    <div class="lmm-sm-preview__text-row">
      <span class="lmm-sm-preview__text-key">Bas</span>
      <span class="lmm-sm-preview__text-val lmm-sm-preview__text-val--empty" id="lmm-prev-bas">—</span>
    </div>
  </div>

  <!-- 5. Continuer -->
  <div class="lmm-sm-preview__footer">
    <button class="lmm-sm-preview__btn" id="lmm-prev-btn-next" onclick="typeof goNext === 'function' && goNext()">
      Continuer
      <svg width="12" height="12" viewBox="0 0 18 18" fill="none"><path d="M3 9H15M15 9L10 4M15 9L10 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
  </div>
</div>

<script>
(function() {
  var p = new URLSearchParams(window.location.search);

  function showImg(imgEl, url) {
    if (!url) return;
    imgEl.src = url;
    imgEl.style.display = 'block';
    imgEl.onload = function() { imgEl.classList.add('loaded'); };
    var empty = imgEl.nextElementSibling;
    if (empty) empty.style.display = 'none';
  }

  function setVal(id, val) {
    var el = document.getElementById(id);
    if (!el || !val) return;
    el.textContent = val;
    el.classList.remove('lmm-sm-preview__text-val--empty');
  }

  // 1. Style
  var stylePhoto = p.get('style_photo');
  if (stylePhoto) {
    var styleImg = document.getElementById('lmm-prev-style-img');
    styleImg.src = stylePhoto;
    styleImg.style.display = 'block';
    styleImg.onload = function() { styleImg.classList.add('loaded'); };
    document.getElementById('lmm-prev-empty').style.display = 'none';
  }

  // 2. Tissu
  showImg(document.getElementById('lmm-prev-tissu-img'), p.get('tissu_photo'));

  // 3. Lining + Boutons
  showImg(document.getElementById('lmm-prev-lining-img'), p.get('lining_photo'));
  showImg(document.getElementById('lmm-prev-bouton-img'), p.get('bouton_photo'));

  // 4. Textes
  setVal('lmm-prev-const-val', p.get('construction'));
  setVal('lmm-prev-hauteur', p.get('hauteur'));
  setVal('lmm-prev-bas', p.get('bas'));

  // Cas 1 — bfcache : page servie depuis le cache navigateur (bouton retour)
  window.addEventListener('pageshow', function(e) {
    if (e.persisted) window.location.reload(true);
  });

  // Cas 2 — CDN cache vide : contenu absent ou invisible
  function checkBlankPage() {
    var main = document.querySelector('.lmm-sm-main');
    if (!main || main.getBoundingClientRect().height < 50) {
      window.location.reload(true);
    }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() { setTimeout(checkBlankPage, 300); });
  } else {
    setTimeout(checkBlankPage, 300);
  }
})();
</script>
