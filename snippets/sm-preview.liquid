{% comment %} Panneau de prévisualisation — Configurateur Custom {% endcomment %}

<style>
  .lmm-sm-preview {
    position: fixed;
    top: 72px;
    right: 0;
    width: 300px;
    height: calc(100vh - 72px);
    background: #fff;
    border-left: 1px solid #E8E2DA;
    display: flex;
    flex-direction: column;
    z-index: 50;
    overflow: hidden;
  }

  .lmm-sm-preview__header {
    padding: 20px 20px 14px;
    border-bottom: 1px solid #E8E2DA;
    flex-shrink: 0;
  }

  .lmm-sm-preview__label {
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #C9A96E;
    margin-bottom: 4px;
  }

  .lmm-sm-preview__title {
    font-family: Georgia, serif;
    font-size: 14px;
    color: #1C1C1C;
    font-weight: 400;
  }

  /* Photo principale (tissu) */
  .lmm-sm-preview__main {
    flex: 1;
    min-height: 0;
    position: relative;
    background: #F0EBE5;
    overflow: hidden;
  }

  .lmm-sm-preview__main-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.3s ease;
  }

  .lmm-sm-preview__main-empty {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }

  .lmm-sm-preview__main-empty-icon {
    width: 48px;
    height: 48px;
    opacity: 0.18;
  }

  .lmm-sm-preview__main-empty-text {
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #C8BBB0;
    text-align: center;
    padding: 0 20px;
  }

  .lmm-sm-preview__main-label {
    position: absolute;
    bottom: 12px;
    left: 12px;
    background: rgba(28,28,28,0.75);
    color: #F5F0EB;
    font-size: 10px;
    letter-spacing: 0.08em;
    padding: 4px 10px;
    backdrop-filter: blur(4px);
    max-width: calc(100% - 24px);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: none;
  }

  /* Vignettes secondaires */
  .lmm-sm-preview__swatches {
    padding: 14px 20px;
    border-top: 1px solid #E8E2DA;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .lmm-sm-preview__swatch-row {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .lmm-sm-preview__swatch {
    width: 36px;
    height: 36px;
    background: #F0EBE5;
    flex-shrink: 0;
    overflow: hidden;
    position: relative;
  }

  .lmm-sm-preview__swatch img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .lmm-sm-preview__swatch img.loaded {
    opacity: 1;
  }

  .lmm-sm-preview__swatch-info {
    flex: 1;
    min-width: 0;
  }

  .lmm-sm-preview__swatch-key {
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #C8BBB0;
    margin-bottom: 2px;
  }

  .lmm-sm-preview__swatch-val {
    font-size: 12px;
    color: #1C1C1C;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-family: Georgia, serif;
  }

  .lmm-sm-preview__swatch-val--empty {
    color: #D0C8C0;
    font-style: italic;
    font-size: 11px;
    font-family: inherit;
  }

  /* Labels texte (pantalon, ourlet) */
  .lmm-sm-preview__texts {
    padding: 0 20px 14px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .lmm-sm-preview__text-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .lmm-sm-preview__text-key {
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #C8BBB0;
  }

  .lmm-sm-preview__text-val {
    font-size: 11px;
    color: #1C1C1C;
  }

  .lmm-sm-preview__text-val--empty {
    color: #D0C8C0;
    font-style: italic;
  }

  /* Responsive — barre fixe en bas sur mobile */
  @media (max-width: 860px) {
    .lmm-sm-preview {
      position: fixed;
      top: auto;
      right: 0;
      bottom: 0;
      left: 0;
      width: 100%;
      height: auto;
      flex-direction: row;
      border-left: none;
      border-top: 1px solid #E8E2DA;
      z-index: 50;
    }

    .lmm-sm-preview__header { display: none; }

    .lmm-sm-preview__main {
      width: 56px;
      height: 56px;
      flex: none;
      flex-shrink: 0;
      border-right: 1px solid #E8E2DA;
    }

    .lmm-sm-preview__main-empty { display: none; }
    .lmm-sm-preview__main-label { display: none !important; }

    .lmm-sm-preview__swatches {
      flex-direction: row;
      border-top: none;
      border-right: 1px solid #E8E2DA;
      padding: 8px 12px;
      overflow-x: auto;
      gap: 10px;
      flex: 1;
      min-width: 0;
    }

    .lmm-sm-preview__swatch-row {
      flex-direction: column;
      align-items: center;
      gap: 4px;
      flex-shrink: 0;
    }

    .lmm-sm-preview__swatch {
      width: 40px;
      height: 40px;
    }

    .lmm-sm-preview__swatch-info { display: none; }

    .lmm-sm-preview__texts { display: none; }
  }

  /* Ajustement du contenu principal pour laisser place au panneau */
  @media (min-width: 861px) {
    .lmm-sm-main {
      width: auto !important;
      margin-left: 5% !important;
      margin-right: 320px !important;
    }
  }
  @media (max-width: 860px) {
    .lmm-sm-main {
      padding-bottom: 72px !important;
    }
  }
</style>

<div class="lmm-sm-preview" id="lmm-sm-preview">
  <div class="lmm-sm-preview__header">
    <p class="lmm-sm-preview__label">Aperçu</p>
    <p class="lmm-sm-preview__title">Votre complet</p>
  </div>

  <div class="lmm-sm-preview__main" id="lmm-prev-main">
    <img id="lmm-prev-tissu-img" class="lmm-sm-preview__main-img" src="" alt="" style="display:none;">
    <div class="lmm-sm-preview__main-empty" id="lmm-prev-empty">
      <svg class="lmm-sm-preview__main-empty-icon" viewBox="0 0 60 80" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 8 L8 20 L2 22 L2 72 L58 72 L58 22 L52 20 L48 8 L38 14 C36 18 24 18 22 14 Z" stroke="#1C1C1C" stroke-width="1.5" fill="none"/>
        <path d="M22 14 L24 28 L30 34 L36 28 L38 14" stroke="#1C1C1C" stroke-width="1.5" fill="none"/>
        <line x1="10" y1="30" x2="10" y2="68" stroke="#1C1C1C" stroke-width="1" opacity="0.4"/>
        <line x1="50" y1="30" x2="50" y2="68" stroke="#1C1C1C" stroke-width="1" opacity="0.4"/>
      </svg>
      <span class="lmm-sm-preview__main-empty-text">Choisissez votre tissu pour voir l'aperçu</span>
    </div>
    <span class="lmm-sm-preview__main-label" id="lmm-prev-tissu-label"></span>
  </div>

  <div class="lmm-sm-preview__swatches">
    <div class="lmm-sm-preview__swatch-row">
      <div class="lmm-sm-preview__swatch">
        <img id="lmm-prev-lining-img" src="" alt="">
      </div>
      <div class="lmm-sm-preview__swatch-info">
        <p class="lmm-sm-preview__swatch-key">Lining</p>
        <p class="lmm-sm-preview__swatch-val lmm-sm-preview__swatch-val--empty" id="lmm-prev-lining-val">—</p>
      </div>
    </div>
    <div class="lmm-sm-preview__swatch-row">
      <div class="lmm-sm-preview__swatch">
        <img id="lmm-prev-bouton-img" src="" alt="">
      </div>
      <div class="lmm-sm-preview__swatch-info">
        <p class="lmm-sm-preview__swatch-key">Boutons</p>
        <p class="lmm-sm-preview__swatch-val lmm-sm-preview__swatch-val--empty" id="lmm-prev-bouton-val">—</p>
      </div>
    </div>
    <div class="lmm-sm-preview__swatch-row">
      <div class="lmm-sm-preview__swatch">
        <img id="lmm-prev-const-img" src="" alt="">
      </div>
      <div class="lmm-sm-preview__swatch-info">
        <p class="lmm-sm-preview__swatch-key">Construction</p>
        <p class="lmm-sm-preview__swatch-val lmm-sm-preview__swatch-val--empty" id="lmm-prev-const-val">—</p>
      </div>
    </div>
  </div>

  <div class="lmm-sm-preview__texts">
    <div class="lmm-sm-preview__text-row">
      <span class="lmm-sm-preview__text-key">Hauteur</span>
      <span class="lmm-sm-preview__text-val lmm-sm-preview__text-val--empty" id="lmm-prev-hauteur">—</span>
    </div>
    <div class="lmm-sm-preview__text-row">
      <span class="lmm-sm-preview__text-key">Bas</span>
      <span class="lmm-sm-preview__text-val lmm-sm-preview__text-val--empty" id="lmm-prev-bas">—</span>
    </div>
  </div>
</div>

<script>
(function() {
  var p = new URLSearchParams(window.location.search);

  function setImg(imgEl, url) {
    if (!url) return;
    imgEl.src = url;
    imgEl.style.display = 'block';
    imgEl.onload = function() { imgEl.classList.add('loaded'); };
  }

  function setVal(el, val) {
    if (!val) return;
    el.textContent = val;
    el.classList.remove('lmm-sm-preview__swatch-val--empty', 'lmm-sm-preview__text-val--empty');
  }

  // Tissu (photo principale)
  var tissuPhoto = p.get('tissu_photo');
  var tissuNom = p.get('tissu');
  if (tissuPhoto) {
    document.getElementById('lmm-prev-empty').style.display = 'none';
    var img = document.getElementById('lmm-prev-tissu-img');
    img.style.display = 'block';
    img.src = tissuPhoto;
    var lbl = document.getElementById('lmm-prev-tissu-label');
    if (tissuNom) { lbl.textContent = tissuNom; lbl.style.display = 'block'; }
  }

  // Lining
  var liningPhoto = p.get('lining_photo');
  var liningNom = p.get('lining');
  if (liningPhoto) setImg(document.getElementById('lmm-prev-lining-img'), liningPhoto);
  if (liningNom) setVal(document.getElementById('lmm-prev-lining-val'), liningNom);

  // Boutons
  var boutonPhoto = p.get('bouton_photo');
  var boutonNom = p.get('bouton');
  if (boutonPhoto) setImg(document.getElementById('lmm-prev-bouton-img'), boutonPhoto);
  if (boutonNom) setVal(document.getElementById('lmm-prev-bouton-val'), boutonNom);

  // Construction
  var constPhoto = p.get('construction_photo');
  var constNom = p.get('construction');
  if (constPhoto) setImg(document.getElementById('lmm-prev-const-img'), constPhoto);
  if (constNom) setVal(document.getElementById('lmm-prev-const-val'), constNom);

  // Hauteur / Bas
  var hauteur = p.get('hauteur');
  var bas = p.get('bas');
  if (hauteur) setVal(document.getElementById('lmm-prev-hauteur'), hauteur);
  if (bas) setVal(document.getElementById('lmm-prev-bas'), bas);
})();
</script>
