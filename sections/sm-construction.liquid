{% comment %} Construction + Pantalon — Configurateur Custom {% endcomment %}
{% render 'fil-ariane-custom', etape_active: 5 %}
{% render 'sm-preview' %}

<style>
  .lmm-sm-const-wrap { width: 90%; margin: 0 auto; padding: 28px 0 20px; display: flex; flex-direction: column; box-sizing: border-box; }
  @media (min-width: 861px) { .lmm-sm-const-wrap { width: 86%; margin-right: 0; margin-left: 5%; } }
  .lmm-sm-const__header { margin-bottom: 24px; }
  .lmm-sm-const__label { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #C9A96E; margin-bottom: 6px; }
  .lmm-sm-const__title { font-family: Georgia, serif; font-size: 26px; font-weight: 400; color: #1C1C1C; margin-bottom: 4px; }
  .lmm-sm-const__sub { font-size: 13px; color: #8C7B6E; font-weight: 300; line-height: 1.5; }
  .lmm-sm-const__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-bottom: 32px; }
  .lmm-sm-const__card { background: #fff; border: 1px solid rgba(28,28,28,0.1); cursor: pointer; transition: border-color 0.2s, box-shadow 0.2s; display: flex; flex-direction: column; overflow: hidden; }
  .lmm-sm-const__card:hover { border-color: rgba(28,28,28,0.3); box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
  .lmm-sm-const__card--selected { border: 2px solid #1C1C1C !important; }
  .lmm-sm-const__card-photo { width: 100%; aspect-ratio: 4/3; background: #E8E2DB; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .lmm-sm-const__card-photo img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
  .lmm-sm-const__card:hover .lmm-sm-const__card-photo img { transform: scale(1.04); }
  .lmm-sm-const__card-photo-placeholder { font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: #8C7B6E; }
  .lmm-sm-const__card-body { padding: 14px 18px 18px; }
  .lmm-sm-const__name { font-family: Georgia, serif; font-size: 16px; font-weight: 400; color: #1C1C1C; margin-bottom: 6px; }
  .lmm-sm-const__desc { font-size: 12px; color: #8C7B6E; line-height: 1.6; margin-bottom: 6px; }
  .lmm-sm-const__prix { font-size: 13px; color: #1C1C1C; font-weight: 500; }

  /* Séparateur entre les deux sections */
  .lmm-sm-divider { border: none; border-top: 1px solid #E8E2DA; margin: 8px 0 32px; }

  /* Section pantalon */
  .lmm-sm-pant__header { margin-bottom: 20px; }
  .lmm-sm-pant__title { font-family: Georgia, serif; font-size: 22px; font-weight: 400; color: #1C1C1C; margin-bottom: 4px; }
  .lmm-sm-pant__sub { font-size: 13px; color: #8C7B6E; font-weight: 300; line-height: 1.5; }
  .lmm-sm-pant__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-bottom: 32px; }
  .lmm-sm-pant__card { background: #fff; border: 1px solid rgba(28,28,28,0.1); cursor: pointer; transition: border-color 0.2s, box-shadow 0.2s; display: flex; flex-direction: column; overflow: hidden; }
  .lmm-sm-pant__card:hover { border-color: rgba(28,28,28,0.3); box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
  .lmm-sm-pant__card--selected { border: 2px solid #1C1C1C !important; }
  .lmm-sm-pant__card-photo { width: 100%; aspect-ratio: 4/3; background: #E8E2DB; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .lmm-sm-pant__card-photo img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
  .lmm-sm-pant__card:hover .lmm-sm-pant__card-photo img { transform: scale(1.04); }
  .lmm-sm-pant__card-photo-placeholder { font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: #8C7B6E; }
  .lmm-sm-pant__card-body { padding: 14px 18px 18px; }
  .lmm-sm-pant__name { font-family: Georgia, serif; font-size: 16px; font-weight: 400; color: #1C1C1C; margin-bottom: 6px; }
  .lmm-sm-pant__desc { font-size: 12px; color: #8C7B6E; line-height: 1.6; }

  .lmm-sm-const__nav { display: flex; justify-content: center; }
  .lmm-sm-btn { display: inline-block; background: #1C1C1C; color: #F5F0EB; border: none; padding: 16px 36px; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; font-family: inherit; cursor: pointer; transition: background 0.2s; opacity: 0.35; pointer-events: none; }
  .lmm-sm-btn:hover { background: #333; }
  .lmm-sm-btn.active { opacity: 1; pointer-events: auto; }

  @media (max-width: 860px) {
    .lmm-sm-const__grid, .lmm-sm-pant__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 540px) {
    .lmm-sm-const__grid, .lmm-sm-pant__grid { grid-template-columns: 1fr; }
    .lmm-sm-const-wrap { width: 92%; }
  }
</style>

<div class="lmm-sm-const-wrap lmm-sm-main">

  <div class="lmm-sm-const__header">
    <p class="lmm-sm-const__label">Configurateur custom — Étape 5 sur 7</p>
    <h1 class="lmm-sm-const__title">{{ section.settings.titre }}</h1>
    <p class="lmm-sm-const__sub">{{ section.settings.sous_titre }}</p>
  </div>

  <div class="lmm-sm-const__grid" id="const-grid">
    {% for entry in shop.metaobjects.construction.values %}
      <div class="lmm-sm-const__card"
           data-val="{{ entry.nom.value | escape }}"
           data-prix="{{ entry.prix_addon.value | default: 0 }}"
           data-photo="{{ entry.photo.value | image_url: width: 800 | escape }}"
           onclick="selectConst(this)">
        <div class="lmm-sm-const__card-photo">
          {% if entry.photo.value %}
            <img src="{{ entry.photo.value | image_url: width: 600 }}" alt="{{ entry.nom.value }}">
          {% else %}
            <span class="lmm-sm-const__card-photo-placeholder">Photo à venir</span>
          {% endif %}
        </div>
        <div class="lmm-sm-const__card-body">
          <p class="lmm-sm-const__name">{{ entry.nom.value }}</p>
          {% if entry.description.value %}<p class="lmm-sm-const__desc">{{ entry.description.value }}</p>{% endif %}
          {% if entry.prix_addon.value and entry.prix_addon.value != '0' %}
            <p class="lmm-sm-const__prix">+ ${{ entry.prix_addon.value }}</p>
          {% else %}
            <p class="lmm-sm-const__prix">Inclus</p>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>

</div>

<script>
  var selectedConst = null;
  var selectedConstPrix = 0;
  var _p = new URLSearchParams(window.location.search);

  var savedConst = _p.get('construction');
  if (savedConst) {
    var sc = document.querySelector('#const-grid [data-val="' + savedConst + '"]');
    if (sc) selectConst(sc);
  }

  function selectConst(el) {
    document.querySelectorAll('#const-grid .lmm-sm-const__card').forEach(function(c) { c.classList.remove('lmm-sm-const__card--selected'); });
    el.classList.add('lmm-sm-const__card--selected');
    selectedConst = el.dataset.val;
    selectedConstPrix = parseFloat(el.dataset.prix) || 0;
    _p.set('construction', selectedConst);
    _p.set('construction_prix', selectedConstPrix);
    if (el.dataset.photo) _p.set('construction_photo', el.dataset.photo);
    history.replaceState(null, '', '?' + _p.toString());
    var imgEl = document.getElementById('lmm-prev-const-img');
    var valEl = document.getElementById('lmm-prev-const-val');
    if (imgEl && el.dataset.photo) { imgEl.src = el.dataset.photo; imgEl.classList.add('loaded'); }
    if (valEl) { valEl.textContent = selectedConst; valEl.classList.remove('lmm-sm-preview__swatch-val--empty'); }
    var btn = document.getElementById('lmm-prev-btn-next'); if (btn) btn.classList.add('active');
  }

  function goNext() {
    if (!selectedConst) return;
    window.location.href = '/pages/sur-mesure-ourlet?' + _p.toString();
  }
</script>

{% schema %}
{
  "name": "Custom — Construction",
  "settings": [
    { "type": "text", "id": "titre", "label": "Titre", "default": "Construction" },
    { "type": "textarea", "id": "sous_titre", "label": "Sous-titre", "default": "La construction intérieure détermine le tombé, la durabilité et la longévité de votre veston." }
  ],
  "presets": [{ "name": "Custom — Construction" }]
}
{% endschema %}
