<script>
  (function() {
    var params = new URLSearchParams(window.location.search);

    var canvaMap = { 'c1': '{{ section.settings.c1_nom | default: "Thermocollé" }}', 'c2': '{{ section.settings.c2_nom | default: "Mi-entoilé" }}', 'c3': '{{ section.settings.c3_nom | default: "Pleine entoilure" }}' };
    var pantalonMap = { 'p1': '{{ section.settings.p1_nom | default: "Taille basse" }}', 'p2': '{{ section.settings.p2_nom | default: "Taille haute" }}', 'p3': '{{ section.settings.p3_nom | default: "Taille haute pincé" }}' };
    var ourletMap = { 'o1': '{{ section.settings.o1_nom | default: "Ourlet droit" }}', 'o2': '{{ section.settings.o2_nom | default: "Ourlet retourné" }}' };
    var prixMap = { 'c1': params.get('p1'), 'c2': params.get('p2'), 'c3': params.get('p3') };

    var modele = params.get('modele');
    var canva = params.get('canva');
    var pantalon = params.get('pantalon');
    var ourlet = params.get('ourlet');

    if (modele) document.getElementById('recap-modele').textContent = modele.replace(/-/g, ' ').replace(/\b\w/g, function(l){ return l.toUpperCase(); });
    if (canva) document.getElementById('recap-canva').textContent = canvaMap[canva] || canva;
    if (pantalon) document.getElementById('recap-pantalon').textContent = pantalonMap[pantalon] || pantalon;
    if (ourlet) document.getElementById('recap-ourlet').textContent = ourletMap[ourlet] || ourlet;

    // Fetch product photo
    if (modele) {
      fetch('/products/' + modele + '.js')
        .then(function(r) { return r.json(); })
        .then(function(product) {
          var img = product.featured_image || (product.images && product.images[0]);
          if (img) {
            var frame = document.getElementById('recap-photo-frame');
            frame.innerHTML = '<img src="' + img + '" alt="' + (product.title || '') + '">';
          }
        })
        .catch(function() {});
    }

    // Calcul des prix
    var fmt = function(n) { return n.toLocaleString('fr-CA', { style: 'currency', currency: 'CAD', minimumFractionDigits: 2 }); };
    var parseNum = function(str) { if (!str) return 0; var m = decodeURIComponent(str).replace(/\s/g,'').match(/[\d.,]+/); return m ? parseFloat(m[0].replace(',','.')) : 0; };

    var prixBase = params.get('prix') ? parseFloat(params.get('prix')) / 100 : 0;
    var surchargeRaw = canva && prixMap[canva] ? prixMap[canva] : null;
    var surchargeVal = surchargeRaw ? parseNum(surchargeRaw) : 0;
    var sousTotal = prixBase + surchargeVal;
    var tps = sousTotal * 0.05;
    var tvq = sousTotal * 0.09975;
    var total = sousTotal + tps + tvq;

    if (prixBase) document.getElementById('recap-prix-base').textContent = fmt(prixBase);

    if (surchargeVal && surchargeRaw) {
      document.getElementById('recap-row-surcharge').style.display = '';
      document.getElementById('recap-prix-surcharge').textContent = '+ ' + fmt(surchargeVal);
    }

    if (sousTotal) {
      document.getElementById('recap-total').textContent = fmt(sousTotal);
    }
  })();

  function sauvegarderDraft() {
    localStorage.setItem('lmm_draft', window.location.pathname + window.location.search);
  }

  function ajouterAuPanierEtRediriger(destination) {
    sauvegarderDraft();
    var params = new URLSearchParams(window.location.search);
    var modele = params.get('modele');
    if (!modele) { window.location.href = destination; return; }

    var canvaMap = { 'c1': '{{ section.settings.c1_nom | default: "Thermocollé" }}', 'c2': '{{ section.settings.c2_nom | default: "Mi-entoilé" }}', 'c3': '{{ section.settings.c3_nom | default: "Pleine entoilure" }}' };
    var pantalonMap = { 'p1': '{{ section.settings.p1_nom | default: "Taille basse" }}', 'p2': '{{ section.settings.p2_nom | default: "Taille haute" }}', 'p3': '{{ section.settings.p3_nom | default: "Taille haute pincé" }}' };
    var ourletMap = { 'o1': '{{ section.settings.o1_nom | default: "Ourlet droit" }}', 'o2': '{{ section.settings.o2_nom | default: "Ourlet retourné" }}' };

    fetch('/products/' + modele + '.js')
      .then(function(r) { return r.json(); })
      .then(function(product) {
        return fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            id: product.variants[0].id,
            quantity: 1,
            properties: {
              'Construction': canvaMap[params.get('canva')] || params.get('canva') || '',
              'Coupe de pantalon': pantalonMap[params.get('pantalon')] || params.get('pantalon') || '',
              'Ourlet': ourletMap[params.get('ourlet')] || params.get('ourlet') || ''
            }
          })
        });
      })
      .catch(function() {})
      .finally(function() {
        window.location.href = destination;
      });
  }

  function goBackRecap() {
    var params = new URLSearchParams(window.location.search);
    window.location.href = '/pages/configurateur-ourlet?' + params.toString();
  }


</script>

