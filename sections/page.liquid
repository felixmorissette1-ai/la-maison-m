          {% else %}<span class="lmm-canva__card-photo-placeholder">Photo à venir</span>{% endif %}
        </div>
        <div class="lmm-canva__card-bottom">
          <h2 class="lmm-canva__name">{{ section.settings.o2_nom }}</h2>
          <div class="lmm-canva__textbox">{{ section.settings.o2_desc }}</div>
        </div>
      </div>
    </div>

    <div style="text-align:center; flex-shrink:0;">
      <button class="lmm-btn-primary" id="ourlet-next" onclick="goNextOurlet()">Continuer</button>
