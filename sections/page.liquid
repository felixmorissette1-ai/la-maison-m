<script>
  (function() {
    var p = new URLSearchParams(window.location.search);
    var steps = document.querySelectorAll('.lmm-stepper__step');
    var lines = document.querySelectorAll('.lmm-stepper__line');
    if (p.get('ourlet')) {
      steps[2].classList.add('lmm-stepper__step--done');
      steps[2].querySelector('.lmm-stepper__dot').textContent = '✓';
      lines[2].classList.add('lmm-stepper__line--done');
      steps[2].style.cursor = 'pointer';
      steps[2].onclick = function() { window.location.href = '/pages/configurateur-ourlet?' + p.toString(); };
    }
    if (p.get('ourlet') && p.get('canva') && p.get('pantalon')) {
      steps[3].classList.add('lmm-stepper__step--done');
      steps[3].querySelector('.lmm-stepper__dot').textContent = '✓';
      lines[3] && lines[3].classList.add('lmm-stepper__line--done');
      steps[3].style.cursor = 'pointer';
      steps[3].onclick = function() { window.location.href = '/pages/recapitulatif?' + p.toString(); };
    }
  })();

  var selectedPantalon = null;
  var prePantalon = new URLSearchParams(window.location.search).get('pantalon');
  if (prePantalon) { var preCards = document.querySelectorAll('.lmm-canva__card'); preCards.forEach(function(c, i) { if (['p1','p2','p3'][i] === prePantalon) selectPantalon(c, prePantalon); }); }
  function selectPantalon(el, type) {
    document.querySelectorAll('.lmm-canva__card').forEach(function(c) { c.classList.remove('lmm-canva__card--selected'); });
    el.classList.add('lmm-canva__card--selected');
    selectedPantalon = type;
    document.getElementById('pantalon-next').classList.add('active');
    document.getElementById('pantalon-hint').style.visibility = 'hidden';
  }
  function goNextPantalon() {
    if (!selectedPantalon) return;
    var params = new URLSearchParams(window.location.search);
    params.set('pantalon', selectedPantalon);
    window.location.href = '/pages/configurateur-ourlet?' + params.toString();
  }
  function goBackPantalon() {
    var params = new URLSearchParams(window.location.search);
    window.location.href = '/pages/configurateur?' + params.toString();
  }
</script>

