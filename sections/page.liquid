{% comment %} Page générique — La Maison M. {% endcomment %}

<script>
if (history.scrollRestoration) history.scrollRestoration = 'manual';
window.scrollTo(0, 0);
document.addEventListener('DOMContentLoaded', function() {
  var observer = new MutationObserver(function(mutations) {
    mutations.forEach(function(m) {
      var el = m.target;
      if (el.closest && el.closest('.lmm-canva__card')) {
        if (el.style.transform) el.style.transform = 'none';
        if (el.style.scale) el.style.scale = '';
      }
    });
  });
  document.querySelectorAll('.lmm-canva__card, .lmm-canva__card *').forEach(function(el) {
    observer.observe(el, { attributes: true, attributeFilter: ['style'] });
  });
});
</script>

<style>
  .shopify-section:has(.lmm-canva-wrap) { display: block !important; }
  .lmm-canva-wrap { grid-column: 1 / -1; width: 100%; height: calc(100vh - 72px); display: flex; flex-direction: column; padding: 32px 48px 24px; box-sizing: border-box; }
  .lmm-canva__header { margin-bottom: 24px; flex-shrink: 0; }
  .lmm-canva__title { font-family: Georgia, serif; font-size: 28px; font-weight: 400; color: var(--lmm-text); margin-bottom: 6px; }
  .lmm-canva__sub { font-size: 13px; color: var(--lmm-muted); font-weight: 300; line-height: 1.6; }
  .lmm-canva__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; flex: 1; min-height: 0; margin-bottom: 20px; padding-top: 14px; }
  .lmm-canva__card { background: #fff; border: 2px solid rgba(28,28,28,0.1); padding: 0; cursor: pointer; position: relative; transition: border-color 0.2s; display: flex; flex-direction: column; overflow: visible; transform: none !important; }
  .lmm-canva__card:hover { border-color: rgba(28,28,28,0.3); transform: none !important; }
  .lmm-canva__card *, .lmm-canva__card *:hover { transform: none !important; }
  .lmm-canva__card img, .lmm-canva__card img:hover { transform: none !important; transition: none !important; }
  .lmm-canva__card--selected,
  .lmm-canva__card--selected:hover { border-color: var(--lmm-text); }
  .lmm-canva__card--recommended { border-color: var(--lmm-gold); }
  .lmm-badge-recommended { position: absolute; top: -10px; left: 20px; background: var(--lmm-gold); color: var(--lmm-text); font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; padding: 3px 12px; font-weight: 600; white-space: nowrap; z-index: 1; }
  .lmm-canva__card-photo { width: 100%; flex: 1; background: var(--lmm-surface); display: flex; align-items: center; justify-content: center; overflow: hidden; min-height: 0; }
  .lmm-canva__card-photo img { width: 100%; height: 100%; object-fit: cover; transform: none !important; transition: none !important; }
  .lmm-canva__card-photo-placeholder { font-size: 9px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--lmm-muted); text-align: center; padding: 4px; }
  .lmm-canva__card-bottom { padding: 16px 20px 20px; flex-shrink: 0; }
  .lmm-canva__name { font-family: Georgia, serif; font-size: 18px; font-weight: 400; color: var(--lmm-text); margin-bottom: 4px; }
  .lmm-canva__prix { position: absolute; top: -10px; right: 20px; background: var(--lmm-surface); color: var(--lmm-muted); font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; padding: 3px 12px; font-weight: 600; white-space: nowrap; z-index: 1; margin: 0; }
  .lmm-canva__prix--recommande { background: var(--lmm-gold); color: var(--lmm-text); }
  .lmm-canva__textbox { font-size: 12px; color: var(--lmm-muted); font-weight: 300; line-height: 1.7; }
  .lmm-canva__hint { font-size: 12px; color: var(--lmm-muted); margin-top: 12px; }
  #canva-next { opacity: 0.4; pointer-events: none; }
  #canva-next.active { opacity: 1; pointer-events: auto; }
  #pantalon-next { opacity: 0.4; pointer-events: none; }
  #pantalon-next.active { opacity: 1; pointer-events: auto; }
  #ourlet-next { opacity: 0.4; pointer-events: none; }
  #ourlet-next.active { opacity: 1; pointer-events: auto; }
  .lmm-back-btn { display: inline-flex; align-items: center; gap: 8px; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--lmm-muted); text-decoration: none; background: none; border: none; cursor: pointer; padding: 0; flex-shrink: 0; }
  .lmm-back-btn:hover { color: var(--lmm-text); }
  .lmm-back-btn svg { width: 14px; height: 14px; }
  .lmm-stepper-bar { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; flex-shrink: 0; padding: 6px 0; margin-bottom: 10px; }
  .lmm-stepper { display: flex; align-items: center; gap: 0; }
  .lmm-stepper__step { display: flex; flex-direction: column; align-items: center; gap: 6px; }
  .lmm-stepper__dot { width: 20px; height: 20px; border-radius: 50%; border: 1.5px solid var(--lmm-border); background: transparent; display: flex; align-items: center; justify-content: center; font-size: 9px; font-weight: 600; color: var(--lmm-border); transition: all 0.2s; }
  .lmm-stepper__step--done .lmm-stepper__dot { background: var(--lmm-text); border-color: var(--lmm-text); color: #fff; }
  .lmm-stepper__step--active .lmm-stepper__dot { background: var(--lmm-gold); border-color: var(--lmm-gold); color: #fff; }
  .lmm-stepper__label { font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--lmm-border); white-space: nowrap; }
  .lmm-stepper__step--done .lmm-stepper__label { color: var(--lmm-muted); }
  .lmm-stepper__step--done { cursor: pointer; }
  .lmm-stepper__step--done:hover .lmm-stepper__dot { background: var(--lmm-gold); border-color: var(--lmm-gold); }
  .lmm-stepper__step--done:hover .lmm-stepper__label { color: var(--lmm-text); }
  .lmm-stepper__step--active .lmm-stepper__label { color: var(--lmm-text); font-weight: 600; }
  .lmm-stepper__line { width: 120px; height: 1px; background: var(--lmm-border); margin-bottom: 15px; flex-shrink: 0; }
  .lmm-stepper__line--done { background: var(--lmm-text); }
</style>

{% if page.handle == 'configurateur' %}

{% assign recommended = section.settings.recommended %}

<div class="lmm-canva-wrap full-width">
    <div class="lmm-stepper-bar">
      <button class="lmm-back-btn" onclick="goBackCanva()">
        <svg viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M9 2L4 7L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Retour
      </button>
      <div class="lmm-stepper">
        <div class="lmm-stepper__step lmm-stepper__step--active">
          <div class="lmm-stepper__dot">1</div>
          <span class="lmm-stepper__label">Construction</span>
        </div>
        <div class="lmm-stepper__line"></div>
        <div class="lmm-stepper__step">
          <div class="lmm-stepper__dot">2</div>
          <span class="lmm-stepper__label">Pantalon</span>
        </div>
        <div class="lmm-stepper__line"></div>
        <div class="lmm-stepper__step">
          <div class="lmm-stepper__dot">3</div>
          <span class="lmm-stepper__label">Ourlet</span>
        </div>
        <div class="lmm-stepper__line"></div>
        <div class="lmm-stepper__step">
          <div class="lmm-stepper__dot">4</div>
          <span class="lmm-stepper__label">Récapitulatif</span>
        </div>
      </div>
    </div>
    <div class="lmm-canva__header">
      <h1 class="lmm-canva__title">{{ section.settings.titre }}</h1>
      <p class="lmm-canva__sub">{{ section.settings.sous_titre }}</p>
    </div>

    <div class="lmm-canva__grid">
      <div class="lmm-canva__card" id="card-c1" data-desc="{{ section.settings.c1_desc }}" data-label="{{ section.settings.c1_nom }}" onclick="selectCanva(this, 'c1')">
        <span class="lmm-badge-recommended" id="badge-c1" style="display:none">{{ section.settings.badge_recommande }}</span>
        <div class="lmm-canva__card-photo">
          {% if section.settings.c1_photo %}<img src="{{ section.settings.c1_photo | image_url: width: 600 }}" alt="{{ section.settings.c1_nom }}">
          {% else %}<span class="lmm-canva__card-photo-placeholder">Photo à venir</span>{% endif %}
        </div>
        <p class="lmm-canva__prix" id="prix-c1" style="display:none"></p>
        <div class="lmm-canva__card-bottom">
          <h2 class="lmm-canva__name">{{ section.settings.c1_nom }}</h2>
          <div class="lmm-canva__textbox">{{ section.settings.c1_desc }}</div>
        </div>
      </div>

      <div class="lmm-canva__card" id="card-c2" data-desc="{{ section.settings.c2_desc }}" data-label="{{ section.settings.c2_nom }}" onclick="selectCanva(this, 'c2')">
        <span class="lmm-badge-recommended" id="badge-c2" style="display:none">{{ section.settings.badge_recommande }}</span>
        <div class="lmm-canva__card-photo">
          {% if section.settings.c2_photo %}<img src="{{ section.settings.c2_photo | image_url: width: 600 }}" alt="{{ section.settings.c2_nom }}">
          {% else %}<span class="lmm-canva__card-photo-placeholder">Photo à venir</span>{% endif %}
        </div>
        <p class="lmm-canva__prix" id="prix-c2" style="display:none"></p>
        <div class="lmm-canva__card-bottom">
          <h2 class="lmm-canva__name">{{ section.settings.c2_nom }}</h2>
          <div class="lmm-canva__textbox">{{ section.settings.c2_desc }}</div>
        </div>
      </div>

      <div class="lmm-canva__card" id="card-c3" data-desc="{{ section.settings.c3_desc }}" data-label="{{ section.settings.c3_nom }}" onclick="selectCanva(this, 'c3')">
        <span class="lmm-badge-recommended" id="badge-c3" style="display:none">{{ section.settings.badge_recommande }}</span>
        <div class="lmm-canva__card-photo">
          {% if section.settings.c3_photo %}<img src="{{ section.settings.c3_photo | image_url: width: 600 }}" alt="{{ section.settings.c3_nom }}">
          {% else %}<span class="lmm-canva__card-photo-placeholder">Photo à venir</span>{% endif %}
        </div>
        <p class="lmm-canva__prix" id="prix-c3" style="display:none"></p>
        <div class="lmm-canva__card-bottom">
          <h2 class="lmm-canva__name">{{ section.settings.c3_nom }}</h2>
          <div class="lmm-canva__textbox">{{ section.settings.c3_desc }}</div>
        </div>
      </div>
    </div>

    <div style="text-align:center; flex-shrink:0;">
      <button class="lmm-btn-primary" id="canva-next" onclick="goNext()">Continuer</button>
      <p class="lmm-canva__hint" id="canva-hint">Sélectionnez une construction pour continuer</p>
    </div>
</div>

<script>
  (function() {
    var params = new URLSearchParams(window.location.search);

    // Prix
    [['p1','prix-c1'],['p2','prix-c2'],['p3','prix-c3']].forEach(function(pair) {
      var val = params.get(pair[0]);
      var el = document.getElementById(pair[1]);
      if (val && el) { el.textContent = decodeURIComponent(val); el.style.display = ''; }
    });

    // Recommandé
    var recMap = { 'Thermocollé': 'c1', 'Demi canva': 'c2', 'Canva plein': 'c3' };
    var recRaw = params.get('rec') ? decodeURIComponent(params.get('rec')) : '';
    var rec = recMap[recRaw] || '{{ section.settings.recommended }}';
    if (rec) {
      var card = document.getElementById('card-' + rec);
      var badge = document.getElementById('badge-' + rec);
      if (card) card.classList.add('lmm-canva__card--recommended');
      if (badge) badge.style.display = '';
      var prixRec = document.getElementById('prix-' + rec);
      if (prixRec) prixRec.classList.add('lmm-canva__prix--recommande');
    }
  })();

  (function() {
    var p = new URLSearchParams(window.location.search);
    var steps = document.querySelectorAll('.lmm-stepper__step');
    var lines = document.querySelectorAll('.lmm-stepper__line');
    var dests = [null, '/pages/configurateur-pantalon', '/pages/configurateur-ourlet', '/pages/recapitulatif'];
    var params = ['canva', 'pantalon', 'ourlet'];
    params.forEach(function(param, i) {
      if (p.get(param)) {
        var step = steps[i + 1];
        step.classList.add('lmm-stepper__step--done');
        step.querySelector('.lmm-stepper__dot').textContent = '✓';
        lines[i].classList.add('lmm-stepper__line--done');
        step.style.cursor = 'pointer';
        step.onclick = (function(dest) { return function() { window.location.href = dest + '?' + p.toString(); }; })(dests[i + 1]);
      }
    });
  })();

  var selectedCanva = null;
  var preCanva = new URLSearchParams(window.location.search).get('canva');
  if (preCanva) { var preEl = document.getElementById('card-' + preCanva); if (preEl) selectCanva(preEl, preCanva); }
  function selectCanva(el, type) {
    document.querySelectorAll('.lmm-canva__card').forEach(function(c) { c.classList.remove('lmm-canva__card--selected'); });
    el.classList.add('lmm-canva__card--selected');
    selectedCanva = type;
    document.getElementById('canva-next').classList.add('active');
    document.getElementById('canva-hint').style.visibility = 'hidden';
  }
  function goNext() {
    if (!selectedCanva) return;
    var params = new URLSearchParams(window.location.search);
    params.set('canva', selectedCanva);
    window.location.href = '/pages/configurateur-pantalon?' + params.toString();
  }
  function goBackCanva() {
    var modele = new URLSearchParams(window.location.search).get('modele');
    window.location.href = modele ? '/products/' + modele : '/collections/all';
  }
</script>

