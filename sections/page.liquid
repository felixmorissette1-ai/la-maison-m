<script>
  (function() {
    var p = new URLSearchParams(window.location.search);
    var steps = document.querySelectorAll('.lmm-stepper__step');
    var lines = document.querySelectorAll('.lmm-stepper__line');
    if (p.get('canva') && p.get('pantalon') && p.get('ourlet')) {
      steps[3].classList.add('lmm-stepper__step--done');
      steps[3].querySelector('.lmm-stepper__dot').textContent = '✓';
      lines[3] && lines[3].classList.add('lmm-stepper__line--done');
      steps[3].style.cursor = 'pointer';
      steps[3].onclick = function() { window.location.href = '/pages/recapitulatif?' + p.toString(); };
    }
  })();

  var selectedOurlet = null;
  var preOurlet = new URLSearchParams(window.location.search).get('ourlet');
  if (preOurlet) { var preOurletCards = document.querySelectorAll('.lmm-canva__card'); preOurletCards.forEach(function(c, i) { if (['o1','o2'][i] === preOurlet) selectOurlet(c, preOurlet); }); }
  function selectOurlet(el, type) {
    document.querySelectorAll('.lmm-canva__card').forEach(function(c) { c.classList.remove('lmm-canva__card--selected'); });
    el.classList.add('lmm-canva__card--selected');
    selectedOurlet = type;
    document.getElementById('ourlet-next').classList.add('active');
    document.getElementById('ourlet-hint').style.visibility = 'hidden';
  }
  function goNextOurlet() {
    if (!selectedOurlet) return;
    var params = new URLSearchParams(window.location.search);
    params.set('ourlet', selectedOurlet);
    window.location.href = '/pages/recapitulatif?' + params.toString();
  }
  function goBackOurlet() {
    var params = new URLSearchParams(window.location.search);
    window.location.href = '/pages/configurateur-pantalon?' + params.toString();
  }
</script>

