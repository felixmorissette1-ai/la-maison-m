{{ 'configurateur.css' | asset_url | stylesheet_tag }}

{% render 'cfg-progress', etape_active: 4 %}

<div class="lmm-cfg-wrap">
  <div>
    <div class="lmm-cfg__header">
      <p class="lmm-cfg__step-label">Sur mesure — Étape 4 sur 7</p>
      <h1 class="lmm-cfg__title">{{ section.settings.titre }}</h1>
      <p class="lmm-cfg__sub">{{ section.settings.sous_titre }}</p>
    </div>

    <div class="lmm-cfg__grid">
      {% for entry in shop.metaobjects.bouton.values %}
        <div class="lmm-cfg__card" data-nom="{{ entry.nom.value | escape }}" data-prix="{{ entry.prix_addon.value | default: 0 }}" onclick="selectBouton(this)">
          <div class="lmm-cfg__card-check"><svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4L3.5 6.5L9 1" stroke="white" stroke-width="1.5" stroke-linecap="round"/></svg></div>
          {% if entry.photo.value %}<img class="lmm-cfg__card-img" src="{{ entry.photo.value | image_url: width: 600 }}" alt="{{ entry.nom.value }}">{% else %}<div class="lmm-cfg__card-img-placeholder">Photo à venir</div>{% endif %}
          <div class="lmm-cfg__card-body">
            <p class="lmm-cfg__card-name">{{ entry.nom.value }}</p>
            {% if entry.description.value %}<p class="lmm-cfg__card-desc">{{ entry.description.value }}</p>{% endif %}
            {% if entry.prix_addon.value and entry.prix_addon.value != '0' %}<p class="lmm-cfg__card-price lmm-cfg__card-price--addon">+ ${{ entry.prix_addon.value }}</p>{% else %}<p class="lmm-cfg__card-price">Inclus</p>{% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="lmm-cfg__nav">
      <a href="/pages/configurateur-lining{{ request.search }}" class="lmm-cfg__btn-back">← Retour</a>
      <button class="lmm-cfg__btn-next" id="cfg-next" onclick="goNext()">Continuer</button>
    </div>
  </div>

  <div class="lmm-cfg__panel">
    <div class="lmm-cfg__panel-box">
      <p class="lmm-cfg__panel-label">Aperçu de votre complet</p>
      <div class="lmm-cfg__panel-img"><span style="font-size:11px;letter-spacing:0.08em;text-transform:uppercase;color:#8C7B6E;">Votre complet</span></div>
      <div class="lmm-cfg__panel-rows">
        <div class="lmm-cfg__panel-row"><span class="lmm-cfg__panel-key">Style</span><span class="lmm-cfg__panel-val" id="panel-style">—</span></div>
        <div class="lmm-cfg__panel-row"><span class="lmm-cfg__panel-key">Tissu</span><span class="lmm-cfg__panel-val" id="panel-tissu">—</span></div>
        <div class="lmm-cfg__panel-row"><span class="lmm-cfg__panel-key">Lining</span><span class="lmm-cfg__panel-val" id="panel-lining">—</span></div>
        <div class="lmm-cfg__panel-row"><span class="lmm-cfg__panel-key">Boutons</span><span class="lmm-cfg__panel-val" id="panel-boutons"><span class="lmm-cfg__panel-val--empty">À choisir</span></span></div>
        <div class="lmm-cfg__panel-row"><span class="lmm-cfg__panel-key">Construction</span><span class="lmm-cfg__panel-val--empty lmm-cfg__panel-val">Étape suivante</span></div>
      </div>
      <div class="lmm-cfg__panel-total">
        <span class="lmm-cfg__panel-total-label">Total estimé</span>
        <span class="lmm-cfg__panel-total-price" id="panel-total">—</span>
      </div>
    </div>
  </div>
</div>

<script>
  var selectedBouton = null;
  var params = new URLSearchParams(window.location.search);
  var prixBase = (parseFloat(params.get('tissu_prix')) || 0) + (parseFloat(params.get('lining_prix')) || 0);
  document.getElementById('panel-style').textContent = params.get('style') || '—';
  document.getElementById('panel-tissu').textContent = params.get('tissu') || '—';
  document.getElementById('panel-lining').textContent = params.get('lining') || '—';
  document.getElementById('panel-total').textContent = prixBase ? '$' + prixBase.toLocaleString('fr-CA') : '—';

  function selectBouton(el) {
    document.querySelectorAll('.lmm-cfg__card').forEach(function(c) { c.classList.remove('selected'); });
    el.classList.add('selected');
    var addon = parseFloat(el.dataset.prix) || 0;
    selectedBouton = { nom: el.dataset.nom, prix: addon };
    document.getElementById('panel-boutons').textContent = addon > 0 ? el.dataset.nom + ' (+$' + addon + ')' : el.dataset.nom;
    document.getElementById('panel-total').textContent = '$' + (prixBase + addon).toLocaleString('fr-CA') ;
    document.getElementById('cfg-next').classList.add('active');
  }

  function goNext() {
    if (!selectedBouton) return;
    var p = new URLSearchParams(window.location.search);
    p.set('boutons', selectedBouton.nom);
    p.set('boutons_prix', selectedBouton.prix);
    window.location.href = '/pages/configurateur-construction?' + p.toString();
  }
</script>

{% schema %}
{
  "name": "Configurateur — Boutons",
  "settings": [
    { "type": "text", "id": "titre", "label": "Titre", "default": "Choisissez vos boutons" },
    { "type": "textarea", "id": "sous_titre", "label": "Sous-titre", "default": "Les boutons apportent une touche finale à votre complet." }
  ],
  "presets": [{ "name": "Configurateur — Boutons" }]
}
{% endschema %}
