{% comment %} Tissu — Configurateur Custom {% endcomment %}
{% render 'fil-ariane-custom', etape_active: 2 %}

<style>
  .lmm-sm-tissu-wrap {
    width: 90%; margin: 0 auto; padding: 28px 0 20px;
    display: flex; flex-direction: column; box-sizing: border-box;
  }
  .lmm-sm-tissu__header { margin-bottom: 24px; }
  .lmm-sm-tissu__label { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #C9A96E; margin-bottom: 6px; }
  .lmm-sm-tissu__title { font-family: Georgia, serif; font-size: 26px; font-weight: 400; color: #1C1C1C; margin-bottom: 4px; }
  .lmm-sm-tissu__sub { font-size: 13px; color: #8C7B6E; font-weight: 300; line-height: 1.5; }
  .lmm-sm-tissu__grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 14px; margin-bottom: 24px;
  }
  .lmm-sm-tissu__card {
    background: #fff; border: 1px solid rgba(28,28,28,0.1);
    cursor: pointer; transition: border-color 0.2s, box-shadow 0.2s;
    display: flex; flex-direction: column; overflow: hidden;
  }
  .lmm-sm-tissu__card:hover { border-color: rgba(28,28,28,0.3); box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
  .lmm-sm-tissu__card--selected { border: 2px solid #1C1C1C !important; }
  .lmm-sm-tissu__card-photo {
    width: 100%; aspect-ratio: 1/1;
    background: #E8E2DB; display: flex; align-items: center; justify-content: center; overflow: hidden;
  }
  .lmm-sm-tissu__card-photo img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
  .lmm-sm-tissu__card:hover .lmm-sm-tissu__card-photo img { transform: scale(1.04); }
  .lmm-sm-tissu__card-photo-placeholder { font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: #8C7B6E; }
  .lmm-sm-tissu__card-body { padding: 12px 16px 16px; }
  .lmm-sm-tissu__name { font-family: Georgia, serif; font-size: 15px; font-weight: 400; color: #1C1C1C; margin-bottom: 4px; }
  .lmm-sm-tissu__meta { font-size: 11px; color: #8C7B6E; margin-bottom: 6px; }
  .lmm-sm-tissu__prix { font-size: 13px; color: #1C1C1C; font-weight: 500; }
  .lmm-sm-tissu__nav { display: flex; justify-content: center; }
  .lmm-sm-btn { display: inline-block; background: #F5F0EB; color: #1C1C1C; border: none; padding: 16px 36px; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; font-family: inherit; cursor: pointer; transition: background 0.2s; opacity: 0.4; pointer-events: none; }
  .lmm-sm-btn:hover { background: #C9A96E; }
  .lmm-sm-btn.active { opacity: 1; pointer-events: auto; }
  @media (max-width: 860px) { .lmm-sm-tissu__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .lmm-sm-tissu__grid { grid-template-columns: 1fr; } .lmm-sm-tissu-wrap { width: 92%; } }
</style>

<div class="lmm-sm-tissu-wrap">
  <div class="lmm-sm-tissu__header">
    <p class="lmm-sm-tissu__label">Configurateur custom — Étape 2 sur 8</p>
    <h1 class="lmm-sm-tissu__title">{{ section.settings.titre }}</h1>
    <p class="lmm-sm-tissu__sub">{{ section.settings.sous_titre }}</p>
  </div>

  <div class="lmm-sm-tissu__grid" id="tissu-grid">
    {% for entry in shop.metaobjects.tissu.values %}
      <div class="lmm-sm-tissu__card"
           data-val="{{ entry.nom.value | escape }}"
           data-prix="{{ entry.prix_base.value | default: 0 }}"
           onclick="selectTissu(this)">
        <div class="lmm-sm-tissu__card-photo">
          {% if entry.photo.value %}
            <img src="{{ entry.photo.value | image_url: width: 600 }}" alt="{{ entry.nom.value }}">
          {% else %}
            <span class="lmm-sm-tissu__card-photo-placeholder">Photo à venir</span>
          {% endif %}
        </div>
        <div class="lmm-sm-tissu__card-body">
          <p class="lmm-sm-tissu__name">{{ entry.nom.value }}</p>
          <p class="lmm-sm-tissu__meta">{% if entry.origine.value %}{{ entry.origine.value }}{% endif %}{% if entry.grammage.value %} · {{ entry.grammage.value }}{% endif %}</p>
          {% if entry.prix_base.value %}<p class="lmm-sm-tissu__prix">${{ entry.prix_base.value }}</p>{% endif %}
        </div>
      </div>
    {% endfor %}
  </div>

  <div class="lmm-sm-tissu__nav">
    <button class="lmm-sm-btn" id="tissu-next" onclick="goNext()">Continuer</button>
  </div>
</div>

<script>
  var selected = null;
  var selectedPrix = 0;
  var _p = new URLSearchParams(window.location.search);

  var savedTissu = _p.get('tissu');
  if (savedTissu) {
    var savedCard = document.querySelector('#tissu-grid [data-val="' + savedTissu + '"]');
    if (savedCard) selectTissu(savedCard);
  }

  function selectTissu(el) {
    document.querySelectorAll('#tissu-grid .lmm-sm-tissu__card').forEach(function(c) { c.classList.remove('lmm-sm-tissu__card--selected'); });
    el.classList.add('lmm-sm-tissu__card--selected');
    selected = el.dataset.val;
    selectedPrix = parseFloat(el.dataset.prix) || 0;
    document.getElementById('tissu-next').classList.add('active');
    _p.set('tissu', selected);
    _p.set('tissu_prix', selectedPrix);
    history.replaceState(null, '', '?' + _p.toString());
  }

  function goNext() {
    if (!selected) return;
    window.location.href = '/pages/sur-mesure-lining?' + _p.toString();
  }
</script>

{% schema %}
{
  "name": "Custom — Tissu",
  "settings": [
    { "type": "text", "id": "titre", "label": "Titre", "default": "Choisissez votre tissu" },
    { "type": "textarea", "id": "sous_titre", "label": "Sous-titre", "default": "Le tissu détermine le prix de base de votre complet sur mesure." }
  ],
  "presets": [{ "name": "Custom — Tissu" }]
}
{% endschema %}
