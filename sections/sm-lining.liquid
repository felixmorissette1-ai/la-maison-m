{% comment %} Lining — Configurateur Custom {% endcomment %}
{% render 'fil-ariane-custom', etape_active: 3 %}
{% render 'sm-preview' %}

<style>
  .lmm-sm-lining-wrap { width: 90%; margin: 0 auto; padding: 28px 0 20px; display: flex; flex-direction: column; box-sizing: border-box; }
  @media (min-width: 861px) { .lmm-sm-lining-wrap { width: 86%; margin-right: 0; margin-left: 5%; } }
  .lmm-sm-lining__header { margin-bottom: 24px; }
  .lmm-sm-lining__label { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--lmm-gold); margin-bottom: 6px; }
  .lmm-sm-lining__title { font-family: Georgia, serif; font-size: 26px; font-weight: 400; color: var(--lmm-text); margin-bottom: 4px; }
  .lmm-sm-lining__sub { font-size: 13px; color: var(--lmm-muted); font-weight: 300; line-height: 1.5; }
  .lmm-sm-lining__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 0; }
  .lmm-sm-lining__card { background: #fff; border: 1px solid rgba(28,28,28,0.1); cursor: pointer; transition: border-color 0.2s, box-shadow 0.2s; display: flex; flex-direction: column; overflow: hidden; }
  .lmm-sm-lining__card:hover { border-color: rgba(28,28,28,0.3); box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
  .lmm-sm-lining__card--selected { border: 2px solid var(--lmm-text) !important; }
  .lmm-sm-lining__card-photo { width: 100%; aspect-ratio: 1/1; background: var(--lmm-surface); display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .lmm-sm-lining__card-photo img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
  .lmm-sm-lining__card:hover .lmm-sm-lining__card-photo img { transform: scale(1.04); }
  .lmm-sm-lining__card-photo-placeholder { font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--lmm-muted); }
  .lmm-sm-lining__card-body { padding: 8px 10px 10px; }
  .lmm-sm-lining__name { font-family: Georgia, serif; font-size: 13px; font-weight: 400; color: var(--lmm-text); margin-bottom: 2px; }
  .lmm-sm-lining__desc { font-size: 10px; color: var(--lmm-muted); margin-bottom: 4px; line-height: 1.4; }
  .lmm-sm-lining__prix { font-size: 12px; color: var(--lmm-text); font-weight: 500; }
  @media (max-width: 1100px) { .lmm-sm-lining__grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 600px) { .lmm-sm-lining__grid { grid-template-columns: repeat(2, 1fr); } .lmm-sm-lining-wrap { width: 92%; } }
</style>

<div class="lmm-sm-lining-wrap lmm-sm-main">
  <div class="lmm-sm-lining__header">
    <p class="lmm-sm-lining__label">Configurateur custom — Étape 3 sur 7</p>
    <h1 class="lmm-sm-lining__title">{{ section.settings.titre }}</h1>
    <p class="lmm-sm-lining__sub">{{ section.settings.sous_titre }}</p>
  </div>

  <div class="lmm-sm-lining__grid" id="lining-grid">
    {% for entry in shop.metaobjects.lining.values %}
      <div class="lmm-sm-lining__card"
           data-val="{{ entry.nom.value | escape }}"
           data-prix="{{ entry.prix_addon.value | default: 0 }}"
           data-photo="{{ entry.photo.value | image_url: width: 800 | escape }}"
           onclick="selectLining(this)">
        <div class="lmm-sm-lining__card-photo">
          {% if entry.photo.value %}
            <img src="{{ entry.photo.value | image_url: width: 600 }}" alt="{{ entry.nom.value }}">
          {% else %}
            <span class="lmm-sm-lining__card-photo-placeholder">Photo à venir</span>
          {% endif %}
        </div>
        <div class="lmm-sm-lining__card-body">
          <p class="lmm-sm-lining__name">{{ entry.nom.value }}</p>

          {% if entry.description.value %}<p class="lmm-sm-lining__desc">{{ entry.description.value }}</p>{% endif %}
          {% if entry.prix_addon.value and entry.prix_addon.value != '0' %}
            <p class="lmm-sm-lining__prix">+ ${{ entry.prix_addon.value }}</p>
          {% else %}
            <p class="lmm-sm-lining__prix">Inclus</p>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>

</div>

<script>
  var selected = null;
  var selectedPrix = 0;
  var _p = new URLSearchParams(window.location.search);

  var savedLining = _p.get('lining');
  if (savedLining) {
    var savedCard = document.querySelector('#lining-grid [data-val="' + savedLining + '"]');
    if (savedCard) selectLining(savedCard);
  }

  function selectLining(el) {
    document.querySelectorAll('#lining-grid .lmm-sm-lining__card').forEach(function(c) { c.classList.remove('lmm-sm-lining__card--selected'); });
    el.classList.add('lmm-sm-lining__card--selected');
    selected = el.dataset.val;
    selectedPrix = parseFloat(el.dataset.prix) || 0;
    var btn = document.getElementById('lmm-prev-btn-next'); if (btn) btn.classList.add('active');
    _p.set('lining', selected);
    _p.set('lining_prix', selectedPrix);
    if (el.dataset.photo) _p.set('lining_photo', el.dataset.photo);
    history.replaceState(null, '', '?' + _p.toString());
    // Preview temps réel
    var imgEl = document.getElementById('lmm-prev-lining-img');
    var valEl = document.getElementById('lmm-prev-lining-val');
    if (imgEl && el.dataset.photo) { imgEl.src = el.dataset.photo; imgEl.classList.add('loaded'); }
    if (valEl) { valEl.textContent = selected; valEl.classList.remove('lmm-sm-preview__swatch-val--empty'); }
  }

  function goNext() {
    if (!selected) return;
    _p.set('_t', Date.now()); window.location.href = '/pages/sur-mesure-boutons?' + _p.toString();
  }
</script>

{% schema %}
{
  "name": "Custom — Lining",
  "settings": [
    { "type": "text", "id": "titre", "label": "Titre", "default": "Choisissez votre lining" },
    { "type": "textarea", "id": "sous_titre", "label": "Sous-titre", "default": "Le lining est la doublure intérieure de votre veston." }
  ],
  "presets": [{ "name": "Custom — Lining" }]
}
{% endschema %}
