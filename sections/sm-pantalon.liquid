{% comment %} Pantalon — Configurateur Custom {% endcomment %}
{% render 'fil-ariane-custom', etape_active: 6 %}
{% render 'sm-preview' %}

<style>
  .lmm-smp-wrap {
    width: 90%; margin: 0 auto; padding: 28px 0 20px;
    display: flex; flex-direction: column; box-sizing: border-box;
  }
  .lmm-smp__header { margin-bottom: 16px; flex-shrink: 0; }
  .lmm-smp__label { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #C9A96E; margin-bottom: 6px; }
  .lmm-smp__title { font-family: Georgia, serif; font-size: 26px; font-weight: 400; color: #1C1C1C; margin-bottom: 4px; }
  .lmm-smp__sub { font-size: 13px; color: #8C7B6E; font-weight: 300; line-height: 1.5; }
  .lmm-smp__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; flex: 1; min-height: 0; margin-bottom: 16px; }
  .lmm-smp__card { background: #fff; border: 1px solid rgba(28,28,28,0.1); cursor: pointer; transition: border-color 0.2s, box-shadow 0.2s; display: flex; flex-direction: column; overflow: hidden; min-height: 0; }
  .lmm-smp__card:hover { border-color: rgba(28,28,28,0.3); box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
  .lmm-smp__card--selected { border: 2px solid #1C1C1C !important; }
  .lmm-smp__card-photo { width: 100%; flex: 1; min-height: 0; background: #E8E2DB; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .lmm-smp__card-photo img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
  .lmm-smp__card:hover .lmm-smp__card-photo img { transform: scale(1.04); }
  .lmm-smp__card-photo-placeholder { font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: #8C7B6E; }
  .lmm-smp__card-body { padding: 14px 18px 18px; flex-shrink: 0; }
  .lmm-smp__name { font-family: Georgia, serif; font-size: 17px; font-weight: 400; color: #1C1C1C; margin-bottom: 8px; }
  .lmm-smp__desc { font-size: 12px; color: #8C7B6E; line-height: 1.6; }
  .lmm-smp__nav { display: flex; justify-content: center; flex-shrink: 0; }
  .lmm-sm-btn { display: inline-block; background: #1C1C1C; color: #F5F0EB; border: none; padding: 16px 36px; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; font-family: inherit; cursor: pointer; transition: background 0.2s; opacity: 0.35; pointer-events: none; }
  .lmm-sm-btn:hover { background: #333; }
  .lmm-sm-btn.active { opacity: 1; pointer-events: auto; }
  @media (min-width: 861px) { .lmm-smp-wrap { width: 86%; margin-right: 0; margin-left: 5%; } }
  @media (max-width: 860px) { .lmm-smp-wrap { height: auto; width: 92%; } .lmm-smp__grid { grid-template-columns: 1fr; } }
</style>

<div class="lmm-smp-wrap lmm-sm-main">
  <div class="lmm-smp__header">
    <p class="lmm-smp__label">Configurateur custom — Étape 6 sur 8</p>
    <h1 class="lmm-smp__title">{{ section.settings.titre }}</h1>
    <p class="lmm-smp__sub">{{ section.settings.sous_titre }}</p>
  </div>

  <div class="lmm-smp__grid" id="smp-grid">
    {% for entry in shop.metaobjects.hauteur_pantalon.values %}
      <div class="lmm-smp__card"
           data-val="{{ entry.nom.value | escape }}"
           onclick="selectCard(this, '{{ entry.nom.value | escape }}')">
        <div class="lmm-smp__card-photo">
          {% if entry.photo.value %}
            <img src="{{ entry.photo.value | image_url: width: 600 }}" alt="{{ entry.nom.value }}">
          {% else %}
            <span class="lmm-smp__card-photo-placeholder">Photo à venir</span>
          {% endif %}
        </div>
        <div class="lmm-smp__card-body">
          <h2 class="lmm-smp__name">{{ entry.nom.value }}</h2>
          {% if entry.description.value %}<p class="lmm-smp__desc">{{ entry.description.value }}</p>{% endif %}
        </div>
      </div>
    {% endfor %}
  </div>

  <div class="lmm-smp__nav">
    <button class="lmm-sm-btn" id="smp-next" onclick="goNext()">Continuer</button>
  </div>
</div>

<script>
  function ajusterHauteur() {
    var wrap = document.querySelector('.lmm-smp-wrap');
    if (!wrap) return;
    var top = wrap.getBoundingClientRect().top + window.scrollY;
    var bottomOffset = window.innerWidth <= 860 ? 64 : 8;
    wrap.style.height = (window.innerHeight - top - bottomOffset) + 'px';
  }
  ajusterHauteur();
  window.addEventListener('resize', ajusterHauteur);

  var selected = null;
  var _p = new URLSearchParams(window.location.search);

  var savedHauteur = _p.get('hauteur');
  if (savedHauteur) {
    var savedCard = document.querySelector('#smp-grid [data-val="' + savedHauteur + '"]');
    if (savedCard) selectCard(savedCard, savedHauteur);
  }

  function selectCard(el, val) {
    document.querySelectorAll('#smp-grid .lmm-smp__card').forEach(function(c) { c.classList.remove('lmm-smp__card--selected'); });
    el.classList.add('lmm-smp__card--selected');
    selected = val;
    document.getElementById('smp-next').classList.add('active');
    _p.set('hauteur', val);
    history.replaceState(null, '', '?' + _p.toString());
    var valEl = document.getElementById('lmm-prev-hauteur');
    if (valEl) { valEl.textContent = val; valEl.classList.remove('lmm-sm-preview__text-val--empty'); }
  }

  function goNext() {
    if (!selected) return;
    window.location.href = '/pages/sur-mesure-ourlet?' + _p.toString();
  }
</script>

{% schema %}
{
  "name": "Custom — Pantalon",
  "settings": [
    { "type": "text", "id": "titre", "label": "Titre", "default": "Hauteur du pantalon" },
    { "type": "textarea", "id": "sous_titre", "label": "Sous-titre", "default": "Choisissez la hauteur de votre pantalon." }
  ],
  "presets": [{ "name": "Custom — Pantalon" }]
}
{% endschema %}
