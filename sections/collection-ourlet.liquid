{% comment %} Ourlet — Collection La Maison M. {% endcomment %}
{% render 'fil-ariane-collection', etape_active: 3 %}

<style>
  .lmm-ourlet-wrap {
    width: 90%; margin: 0 auto; padding: 28px 0 20px;
    display: flex; flex-direction: column; box-sizing: border-box;
  }
  .lmm-ourlet__header { margin-bottom: 16px; flex-shrink: 0; }
  .lmm-ourlet__label { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: #C9A96E; margin-bottom: 6px; }
  .lmm-ourlet__title { font-family: Georgia, serif; font-size: 26px; font-weight: 400; color: #1C1C1C; margin-bottom: 4px; }
  .lmm-ourlet__sub { font-size: 13px; color: #8C7B6E; font-weight: 300; line-height: 1.5; }
  .lmm-ourlet__grid {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 14px; flex: 1; min-height: 0; margin-bottom: 16px;
  }
  .lmm-ourlet__card {
    background: #fff; border: 1px solid rgba(28,28,28,0.1);
    cursor: pointer; transition: border-color 0.2s, box-shadow 0.2s;
    display: flex; flex-direction: column; overflow: hidden; min-height: 0;
  }
  .lmm-ourlet__card:hover { border-color: rgba(28,28,28,0.3); box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
  .lmm-ourlet__card--selected { border: 2px solid #1C1C1C !important; }
  .lmm-ourlet__card-photo {
    width: 100%; flex: 1; min-height: 0;
    background: #E8E2DB; display: flex; align-items: center; justify-content: center; overflow: hidden;
  }
  .lmm-ourlet__card-photo img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
  .lmm-ourlet__card:hover .lmm-ourlet__card-photo img { transform: scale(1.04); }
  .lmm-ourlet__card-photo-placeholder { font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: #8C7B6E; }
  .lmm-ourlet__card-body { padding: 14px 18px 18px; flex-shrink: 0; }
  .lmm-ourlet__name { font-family: Georgia, serif; font-size: 17px; font-weight: 400; color: #1C1C1C; margin-bottom: 8px; }
  .lmm-ourlet__desc { font-size: 12px; color: #8C7B6E; line-height: 1.6; margin-bottom: 0; }
  .lmm-ourlet__nav { display: flex; justify-content: center; flex-shrink: 0; }
  #ourlet-next { opacity: 0.4; pointer-events: none; }
  #ourlet-next.active { opacity: 1; pointer-events: auto; }
  @media (max-width: 860px) {
    .lmm-ourlet-wrap { height: auto; width: 92%; }
    .lmm-ourlet__grid { grid-template-columns: 1fr; }
  }
</style>

<div class="lmm-ourlet-wrap">

  <div class="lmm-ourlet__header">
    <p class="lmm-ourlet__label">Collection — Étape 3 sur 4</p>
    <h1 class="lmm-ourlet__title">Bas de pantalon</h1>
    <p class="lmm-ourlet__sub">Choisissez la finition du bas de votre pantalon.</p>
  </div>

  <div class="lmm-ourlet__grid" id="ourlet-grid">

    <div class="lmm-ourlet__card" data-val="Simple" onclick="selectCard(this, 'Simple')">
      <div class="lmm-ourlet__card-photo">
        <span class="lmm-ourlet__card-photo-placeholder">Photo à venir</span>
      </div>
      <div class="lmm-ourlet__card-body">
        <h2 class="lmm-ourlet__name">Simple</h2>
        <p class="lmm-ourlet__desc">Ourlet droit, classique et sobre.</p>
      </div>
    </div>

    <div class="lmm-ourlet__card" data-val="Revers" onclick="selectCard(this, 'Revers')">
      <div class="lmm-ourlet__card-photo">
        <span class="lmm-ourlet__card-photo-placeholder">Photo à venir</span>
      </div>
      <div class="lmm-ourlet__card-body">
        <h2 class="lmm-ourlet__name">Avec revers</h2>
        <p class="lmm-ourlet__desc">Revers replié vers l'extérieur, style britannique traditionnel.</p>
      </div>
    </div>

  </div>

  <div class="lmm-ourlet__nav">
    <button class="lmm-btn-primary" id="ourlet-next" onclick="goNext()">Continuer →</button>
  </div>

</div>

<script>
  function ajusterHauteur() {
    var wrap = document.querySelector('.lmm-ourlet-wrap');
    if (!wrap) return;
    var top = wrap.getBoundingClientRect().top + window.scrollY;
    wrap.style.height = (window.innerHeight - top - 8) + 'px';
  }
  ajusterHauteur();
  window.addEventListener('resize', ajusterHauteur);

  var selected = null;

  // Restaurer la sélection si on revient en arrière
  var savedBas = new URLSearchParams(window.location.search).get('bas');
  if (savedBas) {
    var savedBasCard = document.querySelector('#ourlet-grid [data-val="' + savedBas + '"]');
    if (savedBasCard) selectCard(savedBasCard, savedBas);
  }

  function selectCard(el, val) {
    document.querySelectorAll('#ourlet-grid .lmm-ourlet__card').forEach(function(c) { c.classList.remove('lmm-ourlet__card--selected'); });
    el.classList.add('lmm-ourlet__card--selected');
    selected = val;
    document.getElementById('ourlet-next').classList.add('active');
    var _p = new URLSearchParams(window.location.search);
    _p.set('bas', val);
    history.replaceState(null, '', '?' + _p.toString());
  }

  function goNext() {
    if (!selected) return;
    var p = new URLSearchParams(window.location.search);
    p.set('bas', selected);
    window.location.href = '/pages/configurateur-recap?' + p.toString();
  }
</script>

{% schema %}
{
  "name": "Collection — Ourlet",
  "settings": [],
  "presets": [{ "name": "Collection — Ourlet" }]
}
{% endschema %}
