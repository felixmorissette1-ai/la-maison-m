{{ 'configurateur.css' | asset_url | stylesheet_tag }}

{% render 'cfg-progress', etape_active: 7 %}

<div class="lmm-cfg-wrap">
  <div>
    <div class="lmm-cfg__header">
      <p class="lmm-cfg__step-label">Sur mesure — Résumé</p>
      <h1 class="lmm-cfg__title">{{ section.settings.titre }}</h1>
      <p class="lmm-cfg__sub">{{ section.settings.sous_titre }}</p>
    </div>

    <div class="lmm-cfg__resume-grid">
      <div class="lmm-cfg__resume-item"><p class="lmm-cfg__resume-item-label">Style</p><p class="lmm-cfg__resume-item-val" id="r-style">—</p></div>
      <div class="lmm-cfg__resume-item"><p class="lmm-cfg__resume-item-label">Tissu</p><p class="lmm-cfg__resume-item-val" id="r-tissu">—</p><p class="lmm-cfg__resume-item-prix" id="r-tissu-prix"></p></div>
      <div class="lmm-cfg__resume-item"><p class="lmm-cfg__resume-item-label">Lining</p><p class="lmm-cfg__resume-item-val" id="r-lining">—</p><p class="lmm-cfg__resume-item-prix" id="r-lining-prix"></p></div>
      <div class="lmm-cfg__resume-item"><p class="lmm-cfg__resume-item-label">Boutons</p><p class="lmm-cfg__resume-item-val" id="r-boutons">—</p><p class="lmm-cfg__resume-item-prix" id="r-boutons-prix"></p></div>
      <div class="lmm-cfg__resume-item"><p class="lmm-cfg__resume-item-label">Construction</p><p class="lmm-cfg__resume-item-val" id="r-construction">—</p><p class="lmm-cfg__resume-item-prix" id="r-construction-prix"></p></div>
      <div class="lmm-cfg__resume-item"><p class="lmm-cfg__resume-item-label">Pantalon</p><p class="lmm-cfg__resume-item-val" id="r-pantalon">—</p></div>
    </div>

    <div style="background:#F5F0EB; padding:20px 24px; margin-bottom:32px; display:flex; justify-content:space-between; align-items:baseline;">
      <span style="font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:#1C1C1C;">Total</span>
      <span style="font-family:Georgia,serif; font-size:28px; color:#1C1C1C;" id="r-total">—</span>
    </div>

    <div class="lmm-cfg__nav">
      <a href="javascript:history.back()" class="lmm-cfg__btn-back">← Retour</a>
      <button class="lmm-cfg__btn-next active" onclick="ajouterAuPanier()">
        Ajouter au panier
        <svg width="14" height="14" viewBox="0 0 18 18" fill="none" style="margin-left:8px;"><path d="M3 9H15M15 9L10 4M15 9L10 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
    <p id="cfg-panier-erreur" style="color:#c0392b; font-size:12px; margin-top:12px; display:none;">Une erreur est survenue. Veuillez réessayer.</p>
  </div>

  <div class="lmm-cfg__panel">
    <div class="lmm-cfg__panel-box">
      <p class="lmm-cfg__panel-label">Votre complet sur mesure</p>
      <div class="lmm-cfg__panel-img"><span style="font-size:11px;letter-spacing:0.08em;text-transform:uppercase;color:#8C7B6E;">Votre complet</span></div>
      <div class="lmm-cfg__panel-rows" id="panel-rows-resume"></div>
      <div class="lmm-cfg__panel-total">
        <span class="lmm-cfg__panel-total-label">Total</span>
        <span class="lmm-cfg__panel-total-price" id="panel-total-resume">—</span>
      </div>
    </div>
  </div>
</div>

<script>
  var params = new URLSearchParams(window.location.search);
  var champs = [
    { key: 'style', label: 'Style', elId: 'r-style' },
    { key: 'tissu', label: 'Tissu', elId: 'r-tissu', prixKey: 'tissu_prix', prixElId: 'r-tissu-prix' },
    { key: 'lining', label: 'Lining', elId: 'r-lining', prixKey: 'lining_prix', prixElId: 'r-lining-prix' },
    { key: 'boutons', label: 'Boutons', elId: 'r-boutons', prixKey: 'boutons_prix', prixElId: 'r-boutons-prix' },
    { key: 'construction', label: 'Construction', elId: 'r-construction', prixKey: 'construction_prix', prixElId: 'r-construction-prix' },
    { key: 'pantalon', label: 'Pantalon', elId: 'r-pantalon' },
  ];
  var total = 0;
  var panelRows = '';
  champs.forEach(function(c) {
    var val = params.get(c.key) || '—';
    var prix = c.prixKey ? parseFloat(params.get(c.prixKey)) || 0 : 0;
    total += prix;
    document.getElementById(c.elId).textContent = val;
    if (c.prixElId) document.getElementById(c.prixElId).textContent = prix > 0 ? '+$' + prix.toLocaleString('fr-CA') : 'Inclus';
    panelRows += '<div class="lmm-cfg__panel-row"><span class="lmm-cfg__panel-key">' + c.label + '</span><span class="lmm-cfg__panel-val">' + val + (prix > 0 ? ' <span style="color:#C9A96E;font-size:10px;">(+$' + prix + ')</span>' : '') + '</span></div>';
  });
  document.getElementById('r-total').textContent = '$' + total.toLocaleString('fr-CA');
  document.getElementById('panel-total-resume').textContent = '$' + total.toLocaleString('fr-CA');
  document.getElementById('panel-rows-resume').innerHTML = panelRows;

  function ajouterAuPanier() {
    var props = {};
    champs.forEach(function(c) { var v = params.get(c.key); if (v) props[c.label] = v; });
    props['Prix estimé'] = '$' + total.toLocaleString('fr-CA');
    var variantId = {{ section.settings.variant_id | default: 0 }};
    if (!variantId) { alert('Produit non configuré.'); return; }
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1, properties: props })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.id) { window.location.href = '/cart'; }
      else { document.getElementById('cfg-panier-erreur').style.display = 'block'; }
    })
    .catch(function() { document.getElementById('cfg-panier-erreur').style.display = 'block'; });
  }
</script>

{% schema %}
{
  "name": "Configurateur — Résumé",
  "settings": [
    { "type": "text", "id": "titre", "label": "Titre", "default": "Votre complet sur mesure" },
    { "type": "textarea", "id": "sous_titre", "label": "Sous-titre", "default": "Vérifiez vos choix avant de procéder au paiement." },
    { "type": "number", "id": "variant_id", "label": "Variant ID du produit Shopify" }
  ],
  "presets": [{ "name": "Configurateur — Résumé" }]
}
{% endschema %}
